# ─── Database ────────────────────────────────────────────────────────────────
# Supabase → Settings → Database → Connection string (URI mode)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (used by Prisma migrate)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="REPLACE_WITH_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="REPLACE_WITH_SERVICE_ROLE_KEY"

# ─── AI Service ──────────────────────────────────────────────────────────────
# Render deployment URL of FastAPI service
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_SECRET="REPLACE_WITH_SHARED_SECRET"

# ─── Monitoring (Sentry — free tier) ─────────────────────────────────────────
# Create project at sentry.io → Settings → Projects → Client Keys
NEXT_PUBLIC_SENTRY_DSN="https://REPLACE@xxxxxxxx.ingest.sentry.io/xxxxxxxx"
SENTRY_ORG="your-org-slug"
SENTRY_PROJECT="clozest"
# Generate at sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN="REPLACE_WITH_SENTRY_TOKEN"

# ─── Cron ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
# Set same value in Vercel dashboard under Environment Variables
CRON_SECRET="REPLACE_WITH_CRON_SECRET"

# ─── Feature Flags ───────────────────────────────────────────────────────────
NEXT_PUBLIC_AI_CLASSIFICATION_ENABLED="true"
