// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?  @map("password_hash")
  name         String?
  avatarUrl    String?  @map("avatar_url")
  onboarded    Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  styleProfile  StyleProfile?
  wardrobeItems WardrobeItem[]
  outfits       Outfit[]
  preferences   UserPreference[]
  accounts      Account[]
  sessions      Session[]
  healthSnapshots HealthSnapshot[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model StyleProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  styleTypes         String[] @map("style_types")
  favoriteColors     Json?    @map("favorite_colors")
  fashionPreferences Json?    @map("fashion_preferences")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("style_profiles")
}

model WardrobeItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  imageUrl  String   @map("image_url")
  name      String?
  category  String?
  color     String?
  fabric    String?
  pattern   String?
  season    String[] @default([])
  style     String?
  wornCount Int      @default(0) @map("worn_count")
  lastWorn  DateTime? @map("last_worn")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // AI Classification metadata
  aiClassified     Boolean  @default(false) @map("ai_classified")
  aiConfidence     Float?   @map("ai_confidence")
  aiClassifiedAt   DateTime? @map("ai_classified_at")
  aiModelVersion   String?  @map("ai_model_version")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitItems OutfitItem[]

  @@map("wardrobe_items")
}

model Outfit {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  name            String?
  notes           String?
  occasion        String?
  weatherData     Json?     @map("weather_data")
  confidenceScore Float?    @map("confidence_score")
  generatedAt     DateTime  @default(now()) @map("generated_at")
  savedAt         DateTime? @map("saved_at")
  wornAt          DateTime? @map("worn_at")
  wornCount       Int       @default(0) @map("worn_count")
  // Hash of item IDs — used for deduplication so same combo isn't re-suggested
  itemsHash       String?   @map("items_hash")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitItems OutfitItem[]

  @@map("outfits")
}

model OutfitItem {
  outfitId       String @map("outfit_id")
  wardrobeItemId String @map("wardrobe_item_id")

  outfit       Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  wardrobeItem WardrobeItem @relation(fields: [wardrobeItemId], references: [id], onDelete: Cascade)

  @@id([outfitId, wardrobeItemId])
  @@map("outfit_items")
}

model UserPreference {
  id     String @id @default(uuid())
  userId String @map("user_id")
  key    String
  value  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("user_preferences")
}

// Periodic health score snapshots — one per week per user
model HealthSnapshot {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  healthScore Int      @map("health_score")
  variety     Int
  utilisation Int
  totalItems  Int      @map("total_items")
  snappedAt   DateTime @default(now()) @map("snapped_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, snappedAt])
  @@map("health_snapshots")
}
